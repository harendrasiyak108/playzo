{
  "expo": {
    "name": "Playzo",
    "slug": "playzo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "playzo",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.emergent.gamezoneops.vk07cc",
      "infoPlist": {
        "NSContactsUsageDescription": "Pick a customer from your contacts to start a session."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.emergent.gamezoneops.vk07cc",
      "permissions": ["android.permission.READ_CONTACTS"]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 240,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      "expo-font",
      [
        "expo-contacts",
        {
          "contactsPermission": "Pick a customer from your contacts to generate their final bill."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
